{
  "name": "@infracanvas/viewer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/lib/index.js",
  "module": "./dist/lib/index.js",
  "types": "./dist/lib/index.d.ts",
  "files": ["dist/lib"],
  "sideEffects": ["**/*.css"],
  "exports": {
    ".": {
      "types": "./dist/lib/index.d.ts",
      "import": "./dist/lib/index.js"
    },
    "./styles.css": "./dist/lib/styles.css"
  },
  "scripts": {
    "dev": "vite --config vite.config.app.ts",
    "build": "tsc -b && npm run build:app && npm run build:lib && npm run build:css",
    "build:app": "vite build --config vite.config.app.ts",
    "build:lib": "vite build --config vite.config.lib.ts",
    "build:css": "npx @tailwindcss/cli -m -i src/lib-styles.css -o dist/lib/styles.css",
    "postbuild": "cp dist/index.html ../cli/infracanvas/export/viewer_template.html",
    "preview": "vite preview --config vite.config.app.ts",
    "test": "vitest run --config vite.config.app.ts",
    "test:watch": "vitest --config vite.config.app.ts"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@xyflow/react": "^12.6.0",
    "aws-react-icons": "^3.3.0",
    "dagre": "^0.8.5",
    "elkjs": "^0.11.1",
    "lucide-react": "^0.511.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.4",
    "@tailwindcss/vite": "^4.1.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/dagre": "^0.7.52",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.4.1",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.2",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-singlefile": "^2.0.3",
    "vitest": "^4.1.4"
  }
}
